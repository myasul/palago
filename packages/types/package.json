{
  "name": "@palago/types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./market": {
      "types": "./dist/market.d.ts",
      "default": "./dist/market.js"
    },
    "./stock": {
      "types": "./dist/stock.d.ts",
      "default": "./dist/stock.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@palago/db": "*"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
