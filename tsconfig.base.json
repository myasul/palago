{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@palago/db": ["packages/db/src/index.ts"],
      "@palago/db/*": ["packages/db/src/*"],
      "@palago/types": ["packages/types/src/index.ts"],
      "@palago/types/*": ["packages/types/src/*"]
    }
  }
}
