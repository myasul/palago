# Shared database connection string for the web app, ingestion jobs, and db package.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DATABASE

# Direct Postgres connection string used for migrations and other admin-level db tasks.
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# API token for the EODHD dividends and ticker sync jobs.
EODHD_API_KEY=your-eodhd-api-key

# Public base URL for the deployed Next.js web app.
NEXT_PUBLIC_APP_URL=https://palago.ph
